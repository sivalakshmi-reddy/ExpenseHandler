@model IEnumerable<ExpenseHandler.Models.ReportViewModel>

<h2>Expense Reports</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Report</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Employee</th>
            <th>Status</th>
            <th>Created</th>
            <th>Submitted</th>
            <th>Total Amount</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var report in Model)
        {
            <tr>
                <td>@report.EmployeeName</td>
                <td>@report.Status</td>
                <td>@report.CreatedAt.ToShortDateString()</td>
                <td>@(report.SubmittedAt?.ToShortDateString() ?? "-")</td>
                <td>₹ @report.TotalAmount.ToString("N2")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@report.Id" class="btn btn-info btn-sm">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>
